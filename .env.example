APP_NAME=에브리 서울 API
APP_VERSION=1.0.0
ENVIRONMENT=local
DEBUG=false

# Either set DATABASE_URL directly, or set the DB_* values below.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/everyseoul
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=everyseoul

SEOUL_OPEN_API_KEY=your_seoul_open_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

CREATE_DB_TABLES=false
ENABLE_SCHEDULER=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
